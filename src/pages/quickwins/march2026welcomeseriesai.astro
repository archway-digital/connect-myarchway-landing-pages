---
import ArchwayLayout from '../../layouts/ArchwayLayout.astro';
import HeroQuickwins from '../../components/quickwins/HeroQuickwins.astro';
import StatsBar from '../../components/shared/StatsBar.astro';
import TheTruth from '../../components/quickwins/TheTruth.astro';
import WhatYoullSee from '../../components/quickwins/WhatYoullSee.astro';
import WhyItMattersAI from '../../components/quickwins/WhyItMattersAI.astro';
import AuthorityQuickwins from '../../components/quickwins/AuthorityQuickwins.astro';
import PartnerLogos from '../../components/shared/PartnerLogos.astro';
import BottomCTA from '../../components/shared/BottomCTA.astro';
import QuickwinsForm from '../../components/quickwins/QuickwinsForm.astro';
---

<ArchwayLayout
  title="AI Quick Wins for Insurance Agencies | Archway"
  description="See the practical AI workflows insurance agencies are implementing right now. No hype — just real use cases that reduce workload and improve speed."
  ctaText="See the AI Quick Wins"
  ctaHref="#form"
>
  <HeroQuickwins />
  <StatsBar stats={[
    { number: '40%', label: 'of admin tasks are automatable' },
    { number: '3-5', label: 'AI workflows per agency to start' },
    { number: '70%+', label: 'time saved on repetitive tasks' },
  ]} />
  <TheTruth />
  <WhatYoullSee />
  <WhyItMattersAI />
  <AuthorityQuickwins />
  <PartnerLogos />
  <BottomCTA
    heading="Ready to see what AI can do for your agency?"
    subtext="Get the quick wins guide — real workflows, no fluff."
    ctaText="See the AI Quick Wins"
    ctaHref="#form"
  />
  <QuickwinsForm />
</ArchwayLayout>

<script>
  // Scroll-triggered fade animations
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, { threshold: 0.15 });

  document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));

  // Form submission
  const form = document.getElementById('checklist-form');
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const thankYou = document.getElementById('thank-you');
      if (form && thankYou) {
        form.style.display = 'none';
        thankYou.classList.add('active');
      }
    });
  }

  // Smooth scroll for anchor links
  document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', function(e) {
      e.preventDefault();
      const href = (e.currentTarget as HTMLAnchorElement).getAttribute('href');
      if (href) {
        const target = document.querySelector(href);
        if (target) {
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      }
    });
  });
</script>
