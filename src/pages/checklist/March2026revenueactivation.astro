---
import ArchwayLayout from '../../layouts/ArchwayLayout.astro';
import HeroRevenue from '../../components/revenue/HeroRevenue.astro';
import StatsBar from '../../components/shared/StatsBar.astro';
import TheProblem from '../../components/revenue/TheProblem.astro';
import ChecklistCovers from '../../components/revenue/ChecklistCovers.astro';
import WhyItMatters from '../../components/revenue/WhyItMatters.astro';
import AuthorityRevenue from '../../components/revenue/AuthorityRevenue.astro';
import PartnerLogos from '../../components/shared/PartnerLogos.astro';
import BottomCTA from '../../components/shared/BottomCTA.astro';
import RevenueForm from '../../components/revenue/RevenueForm.astro';
---

<ArchwayLayout
  title="Agency Revenue Activation Checklist | Archway"
  description="Download the Revenue Activation Checklist built specifically for independent insurance agencies. Find where revenue is leaking and what to fix first."
  ctaText="Get the Checklist"
  ctaHref="#form"
>
  <HeroRevenue />
  <StatsBar stats={[
    { number: '68%', label: 'of leads never get a follow-up' },
    { number: '35%', label: 'revenue leaks from broken pipelines' },
    { number: '5x', label: 'ROI from structured follow-up' },
  ]} />
  <TheProblem />
  <ChecklistCovers />
  <WhyItMatters />
  <AuthorityRevenue />
  <PartnerLogos />
  <BottomCTA
    heading="Stop leaving revenue on the table."
    subtext="Download the checklist and find out where your agency is leaking revenue."
    ctaText="Get the Checklist"
    ctaHref="#form"
  />
  <RevenueForm />
</ArchwayLayout>

<script>
  // Scroll-triggered fade animations
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, { threshold: 0.15 });

  document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));

  // Smooth scroll for anchor links
  document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', function(e) {
      e.preventDefault();
      const href = (e.currentTarget as HTMLAnchorElement).getAttribute('href');
      if (href) {
        const target = document.querySelector(href);
        if (target) {
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      }
    });
  });
</script>
