---
---

<section class="section section-alt" id="whats-inside">
  <div class="section-inner">
    <div class="checklists-intro fade-up">
      <div class="section-label">What's Inside</div>
      <h2>Three Checklists. Three Verticals. One Spring Cleanup.</h2>
    </div>

    <div class="checklists-stack">
      <!-- Security Checklist -->
      <div class="checklist-detail-card fade-up">
        <div class="checklist-detail-header">
          <div class="checklist-detail-icon security">
            <svg viewBox="0 0 24 24"><path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"/></svg>
          </div>
          <h3>Spring Security Checklist <span>(IT &amp; Cybersecurity)</span></h3>
        </div>
        <p>Run through the exact security items carriers and compliance requirements are looking for &mdash; before your next audit, renewal, or incident.</p>
        <div class="covers-label">Covers:</div>
        <ul class="covers-list">
          <li>
            <svg viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
            Security review and audit status
          </li>
          <li>
            <svg viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
            MFA enforcement across your team
          </li>
          <li>
            <svg viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
            Backup validation and recovery testing
          </li>
          <li>
            <svg viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
            Password hygiene and access controls
          </li>
          <li>
            <svg viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
            Carrier cyber requirement readiness
          </li>
        </ul>
      </div>

      <!-- Marketing Checklist -->
      <div class="checklist-detail-card fade-up">
        <div class="checklist-detail-header">
          <div class="checklist-detail-icon marketing">
            <svg viewBox="0 0 24 24"><path d="M18 11v2h4v-2h-4zm-2 6.61c.96.71 2.21 1.65 3.2 2.39.4-.53.8-1.07 1.2-1.6-.99-.74-2.24-1.68-3.2-2.4-.4.54-.8 1.08-1.2 1.61zM20.4 5.6c-.4-.53-.8-1.07-1.2-1.6-.99.74-2.24 1.68-3.2 2.4.4.53.8 1.07 1.2 1.6.96-.72 2.21-1.65 3.2-2.4zM4 9c-1.1 0-2 .9-2 2v2c0 1.1.9 2 2 2h1l5 3V6L5 9H4zm11.5 3c0-1.33-.58-2.53-1.5-3.35v6.69c.92-.81 1.5-2.01 1.5-3.34z"/></svg>
          </div>
          <h3>Spring Marketing Audit Checklist <span>(Digital Marketing)</span></h3>
        </div>
        <p>Your website and marketing funnel may be working against you without you knowing it. This checklist surfaces what's outdated, broken, or just not converting.</p>
        <div class="covers-label">Covers:</div>
        <ul class="covers-list">
          <li>
            <svg viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
            Website performance and conversion rate
          </li>
          <li>
            <svg viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
            Local SEO and Google presence
          </li>
          <li>
            <svg viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
            Lead capture and form functionality
          </li>
          <li>
            <svg viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
            AMS integration and referral tracking
          </li>
          <li>
            <svg viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
            Brand consistency across channels
          </li>
        </ul>
      </div>

      <!-- AI & Workflow Checklist -->
      <div class="checklist-detail-card fade-up">
        <div class="checklist-detail-header">
          <div class="checklist-detail-icon ai">
            <svg viewBox="0 0 24 24"><path d="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.07.62-.07.94s.02.64.07.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z"/></svg>
          </div>
          <h3>Spring AI &amp; Workflow Readiness Checklist <span>(AI &amp; Automation)</span></h3>
        </div>
        <p>Before you invest in AI tools, know where your actual inefficiencies are. This checklist identifies the manual processes most ready for automation.</p>
        <div class="covers-label">Covers:</div>
        <ul class="covers-list">
          <li>
            <svg viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
            Quoting and documentation workflows
          </li>
          <li>
            <svg viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
            Client communication bottlenecks
          </li>
          <li>
            <svg viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
            Staff time spent on repeatable tasks
          </li>
          <li>
            <svg viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
            Current tool stack and integration gaps
          </li>
          <li>
            <svg viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
            AI readiness score by department
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .checklists-intro {
    max-width: 700px;
    margin-bottom: 48px;
  }

  .checklists-stack {
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  .checklist-detail-card {
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-left: 4px solid var(--orange);
    border-radius: 16px;
    padding: 36px 40px;
    box-shadow: var(--card-shadow);
    transition: all 0.25s;
  }

  .checklist-detail-card:hover {
    box-shadow: var(--card-shadow-hover);
    transform: translateY(-2px);
  }

  .checklist-detail-header {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 16px;
  }

  .checklist-detail-icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .checklist-detail-icon svg {
    width: 24px;
    height: 24px;
  }

  .checklist-detail-icon.security {
    background: rgba(244, 128, 33, 0.12);
  }
  .checklist-detail-icon.security svg {
    fill: var(--orange);
  }

  .checklist-detail-icon.marketing {
    background: rgba(41, 63, 80, 0.12);
  }
  .checklist-detail-icon.marketing svg {
    fill: var(--blue);
  }

  .checklist-detail-icon.ai {
    background: rgba(244, 128, 33, 0.12);
  }
  .checklist-detail-icon.ai svg {
    fill: var(--orange);
  }

  .checklist-detail-header h3 {
    font-size: 20px;
    font-weight: 700;
    color: var(--charcoal);
    line-height: 1.3;
  }

  .checklist-detail-header h3 span {
    font-weight: 500;
    color: var(--text-light);
  }

  .checklist-detail-card > p {
    font-size: 16px;
    line-height: 1.7;
    color: var(--text-light);
    margin-bottom: 20px;
  }

  .covers-label {
    font-size: 13px;
    font-weight: 700;
    color: var(--charcoal);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 12px;
  }

  .covers-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .covers-list li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 15px;
    color: var(--text);
    line-height: 1.5;
  }

  .covers-list li svg {
    width: 18px;
    height: 18px;
    fill: var(--orange);
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .checklist-detail-card {
      padding: 28px 24px;
    }

    .checklist-detail-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
    }

    .checklist-detail-header h3 {
      font-size: 18px;
    }
  }
</style>
