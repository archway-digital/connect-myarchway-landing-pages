---
---

<section class="form-section" id="form">
  <div class="form-inner">
    <div class="form-header fade-up">
      <h2>Get Your Free Checklist &mdash; Takes 30 Seconds</h2>
    </div>
    <div class="form-card fade-up" id="form-card">
      <form id="checklist-form">
        <div class="form-row">
          <div class="form-group">
            <label for="firstname">First Name</label>
            <input type="text" id="firstname" name="firstname" placeholder="First name" required />
          </div>
          <div class="form-group">
            <label for="lastname">Last Name</label>
            <input type="text" id="lastname" name="lastname" placeholder="Last name" required />
          </div>
        </div>
        <div class="form-group">
          <label for="email">Email Address</label>
          <input type="email" id="email" name="email" placeholder="you@youragency.com" required />
        </div>
        <div class="form-group">
          <label for="agency">Agency Name</label>
          <input type="text" id="agency" name="agency" placeholder="Your agency name" required />
        </div>
        <div class="form-group">
          <label>Which checklist do you want?</label>
          <div class="checklist-options">
            <label class="checklist-pill">
              <input type="checkbox" name="checklist" value="security" />
              <span class="pill-label">
                <svg viewBox="0 0 24 24"><path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"/></svg>
                Security
              </span>
            </label>
            <label class="checklist-pill">
              <input type="checkbox" name="checklist" value="marketing" />
              <span class="pill-label">
                <svg viewBox="0 0 24 24"><path d="M18 11v2h4v-2h-4zm-2 6.61c.96.71 2.21 1.65 3.2 2.39.4-.53.8-1.07 1.2-1.6-.99-.74-2.24-1.68-3.2-2.4-.4.54-.8 1.08-1.2 1.61zM20.4 5.6c-.4-.53-.8-1.07-1.2-1.6-.99.74-2.24 1.68-3.2 2.4.4.53.8 1.07 1.2 1.6.96-.72 2.21-1.65 3.2-2.4zM4 9c-1.1 0-2 .9-2 2v2c0 1.1.9 2 2 2h1l5 3V6L5 9H4zm11.5 3c0-1.33-.58-2.53-1.5-3.35v6.69c.92-.81 1.5-2.01 1.5-3.34z"/></svg>
                Marketing
              </span>
            </label>
            <label class="checklist-pill">
              <input type="checkbox" name="checklist" value="ai-workflow" />
              <span class="pill-label">
                <svg viewBox="0 0 24 24"><path d="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.07.62-.07.94s.02.64.07.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z"/></svg>
                AI &amp; Workflow
              </span>
            </label>
            <label class="checklist-pill all-three">
              <input type="checkbox" name="checklist" value="all" />
              <span class="pill-label">
                <svg viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                All Three
              </span>
            </label>
          </div>
        </div>
        <button type="submit" class="form-submit">
          <svg viewBox="0 0 24 24"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/></svg>
          Send Me the Checklist
        </button>
      </form>
      <div class="thank-you" id="thank-you">
        <div class="thank-you-icon">
          <svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
        </div>
        <h3>Your Checklist Is on Its Way.</h3>
        <p>Check your inbox &mdash; your Spring Clean checklist will arrive in the next few minutes.</p>
        <p class="thank-you-detail">While you wait: most agencies that run through this checklist find at least one item that's overdue. If something jumps out and you want a second set of eyes on it, we're easy to reach.</p>
        <a href="#" class="thank-you-cta">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"/></svg>
          Book a Quick Review
        </a>
        <p class="thank-you-micro">30 minutes. No pitch. Just clarity on where you stand.</p>
      </div>
    </div>
    <p class="form-privacy">No spam. No sales pressure. Just the checklist delivered straight to your inbox.</p>
  </div>
</section>

<style>
  .checklist-options {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 6px;
  }

  .checklist-pill {
    cursor: pointer;
  }

  .checklist-pill input[type="checkbox"] {
    display: none;
  }

  .pill-label {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 10px 18px;
    border: 1px solid var(--input-border);
    border-radius: 50px;
    font-size: 14px;
    font-weight: 600;
    color: var(--text);
    background: var(--white);
    transition: all 0.2s;
    user-select: none;
  }

  .pill-label svg {
    width: 16px;
    height: 16px;
    fill: var(--text-light);
    transition: fill 0.2s;
  }

  .pill-label:hover {
    border-color: var(--orange);
    color: var(--orange);
  }

  .pill-label:hover svg {
    fill: var(--orange);
  }

  .checklist-pill input[type="checkbox"]:checked + .pill-label {
    background: var(--orange);
    border-color: var(--orange);
    color: var(--white);
  }

  .checklist-pill input[type="checkbox"]:checked + .pill-label svg {
    fill: var(--white);
  }

  .thank-you-detail {
    font-size: 15px;
    color: var(--text-light);
    line-height: 1.6;
    margin-top: 8px;
  }

  .thank-you-micro {
    font-size: 13px;
    color: var(--text-light);
    margin-top: 8px;
  }

  @media (max-width: 480px) {
    .checklist-options {
      flex-direction: column;
    }

    .pill-label {
      width: 100%;
      justify-content: center;
    }
  }
</style>
