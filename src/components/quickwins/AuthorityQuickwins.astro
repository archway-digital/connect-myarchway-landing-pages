        </div>
      </div>
      <p class="authority-note">This guide reflects real implementations &mdash; not theory.</p>
    </div>
  </div>
</section>

<style>
  .authority-inner {
    text-align: center;
    max-width: 750px;
    margin: 0 auto;
  }

  .authority-inner > p {
    margin-top: 12px;
    margin-bottom: 36px;
  }

  .authority-services {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
    max-width: 560px;
    margin: 0 auto;
  }

  .authority-service {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 15px;
    font-weight: 600;
    color: var(--charcoal);
    padding: 14px 20px;
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: 12px;
    transition: all 0.2s;
  }

  .authority-service:hover {
    border-color: var(--orange);
    box-shadow: 0 2px 8px rgba(244, 128, 33, 0.08);
  }

  .authority-service-icon {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .authority-service-icon svg {
    width: 18px;
    height: 18px;
  }

  .authority-service-icon.workflow { background: rgba(41, 63, 80, 0.1); }
  .authority-service-icon.workflow svg { fill: var(--blue); }
  .authority-service-icon.commission { background: rgba(244, 128, 33, 0.1); }
  .authority-service-icon.commission svg { fill: var(--orange); }
  .authority-service-icon.ams { background: rgba(41, 63, 80, 0.1); }
  .authority-service-icon.ams svg { fill: var(--blue); }
  .authority-service-icon.deploy { background: rgba(244, 128, 33, 0.1); }
  .authority-service-icon.deploy svg { fill: var(--orange); }

  .authority-note {
    margin-top: 36px;
    font-size: 16px;
    color: var(--text-light);
    font-style: italic;
  }

  @media (max-width: 768px) {
    .authority-services {
      grid-template-columns: 1fr;
    }
  }
</style>
