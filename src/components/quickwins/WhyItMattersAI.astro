---
---

<section class="section">
  <div class="section-inner">
    <div class="section-label">Why It Matters</div>
    <h2>The pressure on agencies isn't slowing down.</h2>
    <div class="matters-content">
      <div class="matters-left fade-up">
        <ul class="pressure-list">
          <li>
            <svg viewBox="0 0 24 24"><path d="M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z"/></svg>
            Staffing pressure is real.
          </li>
          <li>
            <svg viewBox="0 0 24 24"><path d="M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z"/></svg>
            Manual workflows slow producers down.
          </li>
          <li>
            <svg viewBox="0 0 24 24"><path d="M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z"/></svg>
            Operational inefficiencies compound over time.
          </li>
        </ul>
        <p>AI, implemented strategically, can:</p>
        <ul class="benefit-list">
          <li>
            <div class="benefit-icon"><svg viewBox="0 0 24 24"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"/></svg></div>
            <div><h4>Reduce admin time</h4></div>
          </li>
          <li>
            <div class="benefit-icon"><svg viewBox="0 0 24 24"><path d="M13 2.05v3.03c3.39.49 6 3.39 6 6.92 0 .9-.18 1.75-.48 2.54l2.6 1.53c.56-1.24.88-2.62.88-4.07 0-5.18-3.95-9.45-9-9.95zM12 19c-3.87 0-7-3.13-7-7 0-3.53 2.61-6.43 6-6.92V2.05c-5.06.5-9 4.76-9 9.95 0 5.52 4.47 10 9.99 10 3.31 0 6.24-1.61 8.06-4.09l-2.6-1.53C16.17 17.98 14.21 19 12 19z"/></svg></div>
            <div><h4>Improve response speed</h4></div>
          </li>
          <li>
            <div class="benefit-icon"><svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg></div>
            <div><h4>Increase consistency</h4></div>
          </li>
          <li>
            <div class="benefit-icon"><svg viewBox="0 0 24 24"><path d="M16 6l2.29 2.29-4.88 4.88-4-4L2 16.59 3.41 18l6-6 4 4 6.3-6.29L22 12V6z"/></svg></div>
            <div><h4>Free producers to sell</h4></div>
          </li>
        </ul>
      </div>
      <div class="fade-up">
        <div class="visual-card">
          <div class="visual-header">
            <span class="visual-dot red"></span>
            <span class="visual-dot yellow"></span>
            <span class="visual-dot green"></span>
            <span class="visual-title">Time Savings with AI</span>
          </div>
          <div class="visual-rows">
            <div class="visual-row">
              <span class="visual-row-label">Renewal Drafts</span>
              <div class="visual-row-bar">
                <div class="bar-segment manual" style="width: 25%">Before</div>
                <div class="bar-segment ai-auto" style="width: 75%">AI</div>
              </div>
            </div>
            <div class="visual-row">
              <span class="visual-row-label">Email Triage</span>
              <div class="visual-row-bar">
                <div class="bar-segment manual" style="width: 20%">Before</div>
                <div class="bar-segment ai-auto" style="width: 80%">AI</div>
              </div>
            </div>
            <div class="visual-row">
              <span class="visual-row-label">Doc Generation</span>
              <div class="visual-row-bar">
                <div class="bar-segment manual" style="width: 15%">Before</div>
                <div class="bar-segment ai-auto" style="width: 85%">AI</div>
              </div>
            </div>
            <div class="visual-row">
              <span class="visual-row-label">Service Routing</span>
              <div class="visual-row-bar">
                <div class="bar-segment manual" style="width: 30%">Before</div>
                <div class="bar-segment ai-auto" style="width: 70%">AI</div>
              </div>
            </div>
            <div class="visual-row">
              <span class="visual-row-label">Commission Rec</span>
              <div class="visual-row-bar">
                <div class="bar-segment manual" style="width: 20%">Before</div>
                <div class="bar-segment ai-auto" style="width: 80%">AI</div>
              </div>
            </div>
          </div>
          <div class="visual-legend">
            <div class="legend-item">
              <div class="legend-dot purple"></div>
              Manual effort remaining
            </div>
            <div class="legend-item">
              <div class="legend-dot green"></div>
              Automated with AI
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .matters-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: start;
    margin-top: 48px;
  }

  .matters-left .lead-text {
    font-size: 20px;
    font-weight: 500;
    color: var(--text);
    margin-bottom: 8px;
  }

  .matters-left > p {
    margin-bottom: 16px;
  }

  .pressure-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 28px;
  }

  .pressure-list li {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 16px;
    color: var(--text);
    font-weight: 500;
  }

  .pressure-list li svg {
    width: 16px;
    height: 16px;
    fill: #ef4444;
    flex-shrink: 0;
  }

  .benefit-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin-top: 28px;
  }

  .benefit-list li {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .benefit-icon {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    background: rgba(86, 54, 209, 0.1);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .benefit-icon svg {
    width: 18px;
    height: 18px;
    fill: var(--purple);
  }

  .benefit-list h4 {
    font-size: 16px;
    font-weight: 600;
    color: var(--charcoal);
  }

  /* AI Savings Visual */
  .visual-card {
    background: var(--card-bg);
    border-radius: 16px;
    padding: 32px;
    border: 1px solid var(--card-border);
    box-shadow: var(--card-shadow);
  }

  .visual-header {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 28px;
  }

  .visual-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .visual-dot.red { background: #ef4444; }
  .visual-dot.yellow { background: #facc15; }
  .visual-dot.green { background: #22c55e; }

  .visual-title {
    font-size: 13px;
    font-weight: 600;
    color: var(--text-light);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-left: 8px;
  }

  .visual-rows {
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-bottom: 24px;
  }

  .visual-row {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .visual-row-label {
    flex-shrink: 0;
    width: 130px;
    font-size: 13px;
    font-weight: 500;
    color: var(--text-light);
    text-align: right;
  }

  .visual-row-bar {
    flex: 1;
    display: flex;
    gap: 4px;
    align-items: center;
  }

  .bar-segment {
    height: 24px;
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    font-weight: 700;
    color: var(--white);
    letter-spacing: 0.3px;
  }

  .bar-segment.manual {
    background: linear-gradient(90deg, #7c3aed, #5636d1);
  }

  .bar-segment.ai-auto {
    background: linear-gradient(90deg, #22c55e, #16a34a);
  }

  .visual-legend {
    display: flex;
    gap: 20px;
    padding-top: 16px;
    border-top: 1px solid var(--border);
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    font-weight: 500;
    color: var(--text-light);
  }

  .legend-dot {
    width: 8px;
    height: 8px;
    border-radius: 2px;
  }

  .legend-dot.purple { background: var(--purple); }
  .legend-dot.green { background: #22c55e; }

  @media (max-width: 768px) {
    .matters-content {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }
</style>
