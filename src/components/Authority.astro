---
---

<section class="section section-light">
  <div class="section-inner">
    <div class="authority-inner fade-up">
      <div class="section-label">About Archway</div>
      <h2>Built for agencies, by the team that works inside them.</h2>
      <p>Archway works exclusively with independent insurance agencies across:</p>
      <div class="authority-services">
        <div class="authority-service">
          <div class="authority-service-icon cyber">
            <svg viewBox="0 0 24 24"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4z"/></svg>
          </div>
          IT &amp; Cybersecurity
        </div>
        <div class="authority-service">
          <div class="authority-service-icon marketing">
            <svg viewBox="0 0 24 24"><path d="M16 6l2.29 2.29-4.88 4.88-4-4L2 16.59 3.41 18l6-6 4 4 6.3-6.29L22 12V6z"/></svg>
          </div>
          Marketing
        </div>
        <div class="authority-service">
          <div class="authority-service-icon ai">
            <svg viewBox="0 0 24 24"><path d="M21 10.12h-6.78l2.74-2.82c-2.73-2.7-7.15-2.8-9.88-.1-2.73 2.71-2.73 7.08 0 9.79s7.15 2.71 9.88 0C18.32 15.65 19 14.08 19 12.1h2c0 1.98-.88 4.55-2.64 6.29-3.51 3.48-9.21 3.48-12.72 0-3.5-3.47-3.53-9.11-.02-12.58s9.14-3.49 12.65 0L21 3v7.12zM12.5 8v4.25l3.5 2.08-.72 1.21L11 13V8h1.5z"/></svg>
          </div>
          AI &amp; Automation
        </div>
      </div>
      <p class="authority-note">This checklist reflects what we see inside real agencies every week.</p>
    </div>
  </div>
</section>

<style>
  .authority-inner {
    text-align: center;
    max-width: 700px;
    margin: 0 auto;
  }

  .authority-inner p {
    margin-top: 12px;
    margin-bottom: 36px;
  }

  .authority-services {
    display: flex;
    justify-content: center;
    gap: 32px;
    flex-wrap: wrap;
  }

  .authority-service {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 15px;
    font-weight: 600;
    color: var(--charcoal);
    padding: 14px 24px;
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: 50px;
  }

  .authority-service-icon {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .authority-service-icon svg {
    width: 18px;
    height: 18px;
  }

  .authority-service-icon.cyber { background: rgba(244, 128, 33, 0.1); }
  .authority-service-icon.cyber svg { fill: var(--orange); }
  .authority-service-icon.marketing { background: rgba(64, 84, 178, 0.1); }
  .authority-service-icon.marketing svg { fill: var(--blue); }
  .authority-service-icon.ai { background: rgba(86, 54, 209, 0.1); }
  .authority-service-icon.ai svg { fill: #5636d1; }

  .authority-note {
    margin-top: 36px;
    font-size: 16px;
    color: var(--text-light);
    font-style: italic;
  }

  @media (max-width: 768px) {
    .authority-services {
      flex-direction: column;
      align-items: center;
    }
  }
</style>
