<section class="section section-dark" id="whats-inside">
  <div class="section-inner">
    <div class="checklist-intro fade-up">
      <div class="section-label">What's Inside</div>
      <h2>This isn't a generic IT checklist.</h2>
      <p>It covers the 12 security areas most commonly overlooked inside insurance agencies, including:</p>
    </div>
    <div class="checklist-grid fade-up">
      <div class="checklist-card">
        <div class="checklist-card-icon">
          <svg viewBox="0 0 24 24"><path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"/></svg>
        </div>
        <h4>MFA Enforcement Validation</h4>
      </div>
      <div class="checklist-card">
        <div class="checklist-card-icon">
          <svg viewBox="0 0 24 24"><path d="M19.35 10.04C18.67 6.59 15.64 4 12 4 9.11 4 6.6 5.64 5.35 8.04 2.34 8.36 0 10.91 0 14c0 3.31 2.69 6 6 6h13c2.76 0 5-2.24 5-5 0-2.64-2.05-4.78-4.65-4.96zM17 13l-5 5-5-5h3V9h4v4h3z"/></svg>
        </div>
        <h4>Backup Testing Documentation</h4>
      </div>
      <div class="checklist-card">
        <div class="checklist-card-icon">
          <svg viewBox="0 0 24 24"><path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/></svg>
        </div>
        <h4>User Access Audits</h4>
      </div>
      <div class="checklist-card">
        <div class="checklist-card-icon">
          <svg viewBox="0 0 24 24"><path d="M20 18c1.1 0 1.99-.9 1.99-2L22 6c0-1.1-.9-2-2-2H4c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2H0v2h24v-2h-4zM4 6h16v10H4V6z"/></svg>
        </div>
        <h4>Endpoint Protection Review</h4>
      </div>
      <div class="checklist-card">
        <div class="checklist-card-icon">
          <svg viewBox="0 0 24 24"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
        </div>
        <h4>Phishing Vulnerability Exposure</h4>
      </div>
      <div class="checklist-card">
        <div class="checklist-card-icon">
          <svg viewBox="0 0 24 24"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z"/></svg>
        </div>
        <h4>Penetration Test History</h4>
      </div>
      <div class="checklist-card">
        <div class="checklist-card-icon">
          <svg viewBox="0 0 24 24"><path d="M15 1H9v2h6V1zm-4 13h2V8h-2v6zm8.03-6.61l1.42-1.42c-.43-.51-.9-.99-1.41-1.41l-1.42 1.42C16.07 4.74 14.12 4 12 4c-4.97 0-9 4.03-9 9s4.03 9 9 9 9-4.03 9-9c0-2.12-.74-4.07-1.97-5.61zM12 20c-3.87 0-7-3.13-7-7s3.13-7 7-7 7 3.13 7 7-3.13 7-7 7z"/></svg>
        </div>
        <h4>Incident Response Readiness</h4>
      </div>
      <div class="checklist-card">
        <div class="checklist-card-icon">
          <svg viewBox="0 0 24 24"><path d="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z"/></svg>
        </div>
        <h4>Compliance Documentation Gaps</h4>
      </div>
    </div>

    <div class="outcomes fade-up">
      <h3>You'll walk away knowing:</h3>
      <div class="outcome-item">
        <div class="outcome-icon green">
          <svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
        </div>
        <p>Where you're solid</p>
      </div>
      <div class="outcome-item">
        <div class="outcome-icon red">
          <svg viewBox="0 0 24 24"><path d="M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z"/></svg>
        </div>
        <p>Where you're exposed</p>
      </div>
      <div class="outcome-item">
        <div class="outcome-icon yellow">
          <svg viewBox="0 0 24 24"><path d="M15 1H9v2h6V1zm-4 13h2V8h-2v6zm8.03-6.61l1.42-1.42c-.43-.51-.9-.99-1.41-1.41l-1.42 1.42C16.07 4.74 14.12 4 12 4c-4.97 0-9 4.03-9 9s4.03 9 9 9 9-4.03 9-9c0-2.12-.74-4.07-1.97-5.61zM12 20c-3.87 0-7-3.13-7-7s3.13-7 7-7 7 3.13 7 7-3.13 7-7 7z"/></svg>
        </div>
        <p>What's urgent</p>
      </div>
      <div class="outcome-item">
        <div class="outcome-icon blue">
          <svg viewBox="0 0 24 24"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"/></svg>
        </div>
        <p>What can wait</p>
      </div>
    </div>
  </div>
</section>

<style>
  .checklist-intro {
    max-width: 640px;
    margin-bottom: 48px;
  }

  .checklist-intro p {
    margin-top: 12px;
  }

  .checklist-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-bottom: 60px;
  }

  .checklist-card {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    padding: 28px 24px;
    transition: all 0.25s;
  }

  .checklist-card:hover {
    border-color: rgba(244, 128, 33, 0.3);
    background: rgba(244, 128, 33, 0.04);
    transform: translateY(-2px);
  }

  .checklist-card-icon {
    width: 44px;
    height: 44px;
    background: rgba(244, 128, 33, 0.12);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 16px;
  }

  .checklist-card-icon svg {
    width: 22px;
    height: 22px;
    fill: var(--orange);
  }

  .checklist-card h4 {
    font-size: 15px;
    font-weight: 600;
    color: var(--white);
    line-height: 1.4;
  }

  .outcomes {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }

  .outcomes h3 {
    grid-column: 1 / -1;
    font-size: 24px;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 4px;
  }

  .outcome-item {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 12px;
    padding: 24px;
    text-align: center;
  }

  .outcome-icon {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    margin: 0 auto 14px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .outcome-icon.green { background: rgba(34, 197, 94, 0.12); }
  .outcome-icon.red { background: rgba(239, 68, 68, 0.12); }
  .outcome-icon.yellow { background: rgba(250, 204, 21, 0.12); }
  .outcome-icon.blue { background: rgba(64, 84, 178, 0.12); }

  .outcome-icon svg { width: 22px; height: 22px; }
  .outcome-icon.green svg { fill: #22c55e; }
  .outcome-icon.red svg { fill: #ef4444; }
  .outcome-icon.yellow svg { fill: #facc15; }
  .outcome-icon.blue svg { fill: #6b7ff5; }

  .outcome-item p {
    font-size: 15px;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.85);
  }

  @media (max-width: 1024px) {
    .checklist-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .outcomes {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .checklist-grid {
      grid-template-columns: 1fr;
    }
    .outcomes {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 480px) {
    .outcomes {
      grid-template-columns: 1fr;
    }
  }
</style>
