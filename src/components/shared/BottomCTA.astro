---
interface Props {
  heading: string;
  subtext?: string;
  ctaText: string;
  ctaHref: string;
}

const { heading, subtext, ctaText, ctaHref } = Astro.props;
---

<section class="cta-section">
  <div class="section-inner" style="text-align: center;">
    <h2>{heading}</h2>
    {subtext && <p>{subtext}</p>}
    <a href={ctaHref} class="cta-button">{ctaText}</a>
  </div>
</section>
