        </div>
        <p>Where revenue is leaking</p>
      </div>
      <div class="outcome-item">
        <div class="outcome-icon yellow">
          <svg viewBox="0 0 24 24"><path d="M14.4 6L14 4H5v17h2v-7h5.6l.4 2h7V6z"/></svg>
        </div>
        <p>Where follow-up breaks down</p>
      </div>
      <div class="outcome-item">
        <div class="outcome-icon green">
          <svg viewBox="0 0 24 24"><path d="M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z"/></svg>
        </div>
        <p>What to fix first</p>
      </div>
    </div>
  </div>
</section>

<style>
  .checklist-intro {
    max-width: 640px;
    margin-bottom: 48px;
  }

  .checklist-intro p {
    margin-top: 12px;
  }

  .checklist-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 60px;
  }

  .checklist-card {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    padding: 28px 24px;
    transition: all 0.25s;
  }

  .checklist-card.span-2 {
    grid-column: span 1;
  }

  .checklist-card:hover {
    border-color: rgba(64, 84, 178, 0.35);
    background: rgba(64, 84, 178, 0.06);
    transform: translateY(-2px);
  }

  .checklist-card-icon {
    width: 44px;
    height: 44px;
    background: rgba(64, 84, 178, 0.15);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 16px;
  }

  .checklist-card-icon svg {
    width: 22px;
    height: 22px;
    fill: #8b9cf7;
  }

  .checklist-card h4 {
    font-size: 15px;
    font-weight: 600;
    color: var(--white);
    line-height: 1.4;
  }

  .outcomes {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .outcomes h3 {
    grid-column: 1 / -1;
    font-size: 24px;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 4px;
  }

  .outcome-item {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 12px;
    padding: 24px;
    text-align: center;
  }

  .outcome-icon {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    margin: 0 auto 14px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .outcome-icon.red { background: rgba(239, 68, 68, 0.12); }
  .outcome-icon.yellow { background: rgba(250, 204, 21, 0.12); }
  .outcome-icon.green { background: rgba(34, 197, 94, 0.12); }

  .outcome-icon svg { width: 22px; height: 22px; }
  .outcome-icon.red svg { fill: #ef4444; }
  .outcome-icon.yellow svg { fill: #facc15; }
  .outcome-icon.green svg { fill: #22c55e; }

  .outcome-item p {
    font-size: 15px;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.85);
  }

  @media (max-width: 1024px) {
    .checklist-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .checklist-grid {
      grid-template-columns: 1fr;
    }
    .outcomes {
      grid-template-columns: 1fr;
    }
  }
</style>
