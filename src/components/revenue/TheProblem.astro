---
---

<section class="section section-light">
  <div class="section-inner">
    <div class="section-label">The Problem</div>
    <h2>Most agencies don't have a marketing problem.</h2>
    <p class="subtitle">They have a follow-up and visibility problem.</p>
    <div class="problem-content">
      <div class="problem-left fade-up">
        <p>We commonly see:</p>
        <ul class="pain-list">
          <li>
            <div class="pain-icon">
              <svg viewBox="0 0 24 24"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"/></svg>
            </div>
            Website leads that sit for days
          </li>
          <li>
            <div class="pain-icon">
              <svg viewBox="0 0 24 24"><path d="M9 11.75c-.69 0-1.25.56-1.25 1.25s.56 1.25 1.25 1.25 1.25-.56 1.25-1.25-.56-1.25-1.25-1.25zm6 0c-.69 0-1.25.56-1.25 1.25s.56 1.25 1.25 1.25 1.25-.56 1.25-1.25-.56-1.25-1.25-1.25zM12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8 0-.29.02-.58.05-.86 2.36-1.05 4.23-2.98 5.21-5.37C11.07 8.33 14.05 10 17.42 10c.78 0 1.53-.09 2.25-.26.21.71.33 1.47.33 2.26 0 4.41-3.59 8-8 8z"/></svg>
            </div>
            Producers relying on memory to follow up
          </li>
          <li>
            <div class="pain-icon">
              <svg viewBox="0 0 24 24"><path d="M21 10.12h-6.78l2.74-2.82c-2.73-2.7-7.15-2.8-9.88-.1-2.73 2.71-2.73 7.08 0 9.79s7.15 2.71 9.88 0C18.32 15.65 19 14.08 19 12.1h2c0 1.98-.88 4.55-2.64 6.29-3.51 3.48-9.21 3.48-12.72 0-3.5-3.47-3.53-9.11-.02-12.58s9.14-3.49 12.65 0L21 3v7.12z"/></svg>
            </div>
            No automated nurture
          </li>
          <li>
            <div class="pain-icon">
              <svg viewBox="0 0 24 24"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zM9 17H7v-7h2v7zm4 0h-2V7h2v10zm4 0h-2v-4h2v4z"/></svg>
            </div>
            No clear reporting tied to revenue
          </li>
          <li>
            <div class="pain-icon">
              <svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/></svg>
            </div>
            No tracking of which campaigns produce actual business
          </li>
        </ul>
      </div>
      <div class="problem-callout fade-up">
        <h3>Activity ≠ growth.</h3>
        <p>Without systemized follow-up and measurement, marketing feels expensive instead of predictable.</p>
        <div class="callout-visual">
          <div class="flow-item">
            <div class="flow-icon lead">
              <svg viewBox="0 0 24 24"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
            </div>
            <span>Lead comes in</span>
          </div>
          <div class="flow-arrow">
            <svg viewBox="0 0 24 24"><path d="M16.01 11H4v2h12.01v3L20 12l-3.99-4z"/></svg>
          </div>
          <div class="flow-item">
            <div class="flow-icon gap">
              <svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/></svg>
            </div>
            <span>No follow-up</span>
          </div>
          <div class="flow-arrow">
            <svg viewBox="0 0 24 24"><path d="M16.01 11H4v2h12.01v3L20 12l-3.99-4z"/></svg>
          </div>
          <div class="flow-item">
            <div class="flow-icon lost">
              <svg viewBox="0 0 24 24"><path d="M12 2C6.47 2 2 6.47 2 12s4.47 10 10 10 10-4.47 10-10S17.53 2 12 2zm5 13.59L15.59 17 12 13.41 8.41 17 7 15.59 10.59 12 7 8.41 8.41 7 12 10.59 15.59 7 17 8.41 13.41 12 17 15.59z"/></svg>
            </div>
            <span>Revenue lost</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .subtitle {
    font-size: 22px;
    font-weight: 500;
    color: var(--text);
    margin-top: -8px;
    margin-bottom: 8px;
  }

  .problem-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: start;
    margin-top: 48px;
  }

  .problem-left p {
    margin-bottom: 24px;
  }

  .problem-left p:first-child {
    font-size: 20px;
    color: var(--text);
    font-weight: 500;
  }

  .pain-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin: 24px 0;
  }

  .pain-list li {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    font-size: 16px;
    line-height: 1.5;
    color: var(--text);
  }

  .pain-icon {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    background: rgba(64, 84, 178, 0.1);
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 1px;
  }

  .pain-icon svg {
    width: 14px;
    height: 14px;
    fill: var(--blue);
  }

  .problem-callout {
    background: var(--light-bg);
    border: 1px solid var(--card-border);
    border-radius: 16px;
    padding: 40px;
    border-left: 4px solid var(--orange);
  }

  .problem-callout h3 {
    font-size: 24px;
    font-weight: 800;
    color: var(--charcoal);
    margin-bottom: 16px;
  }

  .problem-callout p {
    font-size: 16px;
    color: var(--text-light);
    line-height: 1.7;
  }

  .callout-visual {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-top: 32px;
    padding-top: 28px;
    border-top: 1px solid var(--border);
  }

  .flow-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    text-align: center;
  }

  .flow-item span {
    font-size: 11px;
    font-weight: 600;
    color: var(--text-light);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .flow-icon {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .flow-icon svg { width: 22px; height: 22px; }
  .flow-icon.lead { background: rgba(34, 197, 94, 0.15); }
  .flow-icon.lead svg { fill: #22c55e; }
  .flow-icon.gap { background: rgba(250, 204, 21, 0.15); }
  .flow-icon.gap svg { fill: #facc15; }
  .flow-icon.lost { background: rgba(239, 68, 68, 0.15); }
  .flow-icon.lost svg { fill: #ef4444; }

  .flow-arrow svg {
    width: 20px;
    height: 20px;
    fill: #d1d5db;
  }

  @media (max-width: 768px) {
    .problem-content {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .callout-visual {
      flex-wrap: wrap;
    }
  }
</style>
