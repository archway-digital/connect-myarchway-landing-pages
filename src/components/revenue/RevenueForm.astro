---
---

<section class="form-section" id="form">
  <div class="form-inner">
    <div class="form-header fade-up">
      <h2>Get the Agency Revenue Activation Checklist</h2>
      <p>Free download. No sales pitch. Just clarity on where revenue is leaking.</p>
    </div>
    <div class="form-card fade-up" id="form-card">
      <form id="revenue-form">
        <div class="form-group">
          <label for="name">Name</label>
          <input type="text" id="name" name="name" placeholder="Your full name" required />
        </div>
        <div class="form-group">
          <label for="agency">Agency Name</label>
          <input type="text" id="agency" name="agency" placeholder="Your agency name" required />
        </div>
        <div class="form-group">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" placeholder="you@youragency.com" required />
        </div>
        <div class="form-row">
          <div class="form-group">
            <label for="role">Role</label>
            <select id="role" name="role" required>
              <option value="" disabled selected>Select your role</option>
              <option value="owner">Agency Owner / Principal</option>
              <option value="operations">Operations Manager</option>
              <option value="marketing">Marketing Lead</option>
              <option value="producer">Producer / Sales</option>
              <option value="other">Other</option>
            </select>
          </div>
          <div class="form-group">
            <label for="size">Approximate Agency Size</label>
            <select id="size" name="size" required>
              <option value="" disabled selected>Select size</option>
              <option value="1-10">1 – 10 employees</option>
              <option value="11-25">11 – 25 employees</option>
              <option value="26-50">26 – 50 employees</option>
              <option value="51-100">51 – 100 employees</option>
              <option value="100+">100+ employees</option>
            </select>
          </div>
        </div>
        <button type="submit" class="form-submit">
          <svg viewBox="0 0 24 24"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/></svg>
          Send Me the Checklist
        </button>
      </form>
      <div class="thank-you" id="thank-you-revenue">
        <div class="thank-you-icon">
          <svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
        </div>
        <h3>Check your inbox!</h3>
        <p>Your Revenue Activation Checklist is on its way.</p>
        <a href="#" class="thank-you-cta">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"/></svg>
          Book a 15-Minute Marketing System Review
        </a>
      </div>
    </div>
    <p class="form-privacy">We respect your privacy. No spam, ever.</p>
  </div>
</section>

<script>
  const revenueForm = document.getElementById('revenue-form');
  const thankYouRevenue = document.getElementById('thank-you-revenue');

  revenueForm?.addEventListener('submit', (e) => {
    e.preventDefault();
    if (revenueForm) revenueForm.style.display = 'none';
    if (thankYouRevenue) thankYouRevenue.classList.add('active');
  });
</script>
